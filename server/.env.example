# Cloudflare Tunnel token (from Zero Trust dashboard)
CLOUDFLARE_TUNNEL_TOKEN=

# API key for authenticating Android app requests
MESH_API_KEY=

# LLM config (LM Studio on host machine, no API key needed)
# Inside Docker, host.docker.internal reaches the host's localhost
LLM_BASE_URL=http://host.docker.internal:1234
LLM_MODEL=qwen3-8b
