# Android SDK location (auto-generated by Android Studio)
sdk.dir=/path/to/your/Android/sdk

# ARCore Cloud Anchor API Key
# Get this from Google Cloud Console:
# 1. Go to https://console.cloud.google.com/
# 2. Create or select a project
# 3. Enable the "ARCore API" under APIs & Services
# 4. Create an API key under Credentials
# 5. (Recommended) Restrict the key to "ARCore API" only
ARCORE_CLOUD_ANCHOR_API_KEY=your_api_key_here

# Mesh server API key (for Cloudflare tunnel auth)
MESH_SERVER_API_KEY=your_api_key_here
